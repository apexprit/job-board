# ============================================
# Job Board — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# For production deployment, see the comments below.

# --------------------------------------------
# SERVER
# --------------------------------------------
PORT=3001
NODE_ENV=development
HOST=localhost

# --------------------------------------------
# DATABASE
# --------------------------------------------
# Development (SQLite): file:./prisma/dev.db
# Production (PostgreSQL/Supabase): postgresql://user:password@host:5432/dbname
DATABASE_URL=file:./prisma/dev.db

# Direct URL for Prisma migrations (Supabase only — non-pooled connection on port 5432)
# Not needed for local SQLite development
# Production: postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres
# DIRECT_URL=

# --------------------------------------------
# JWT SECRETS
# --------------------------------------------
# Generate with: openssl rand -base64 32
# MUST be at least 32 characters in production
JWT_SECRET=your_jwt_secret_key_here_at_least_32_characters
JWT_REFRESH_SECRET=your_refresh_secret_key_here_at_least_32_characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --------------------------------------------
# REDIS (optional)
# --------------------------------------------
# Leave empty to use in-memory fallback (suitable for free tier)
REDIS_URL=

# --------------------------------------------
# CORS
# --------------------------------------------
# Comma-separated list of allowed origins
# Development: http://localhost:5173
# Production: https://your-app.vercel.app,https://your-custom-domain.com
CORS_ORIGIN=http://localhost:5173

# --------------------------------------------
# RENDER (auto-detected)
# --------------------------------------------
# Render sets this automatically — no need to configure
# RENDER=true

# --------------------------------------------
# LOGGING
# --------------------------------------------
LOG_LEVEL=info

# --------------------------------------------
# CLIENT (Vite)
# --------------------------------------------
# Set VITE_API_URL in client/.env for production
# Development: http://localhost:3001/api
# Production: https://your-api.onrender.com/api
# VITE_API_URL=http://localhost:3001/api
